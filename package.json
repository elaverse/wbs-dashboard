{
  "name": "wbs-dashboard",
  "version": "1.0.0",
  "description": "WBS 대시보드 - 입력/수정/삭제/조회",
  "main": "dist-electron/main.js",
  "author": "",
  "build": {
    "appId": "com.wbs.dashboard",
    "productName": "WBS Dashboard",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "WBS Dashboard",
      "installerLanguages": ["ko"],
      "language": "1042"
    }
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && tsc -p electron",
    "dist": "npm run build && electron-builder --win",
    "build:web": "vite build",
    "build:electron": "tsc -p electron",
    "preview": "vite preview -p 5173",
    "start": "electron .",
    "upload:s3": "node scripts/upload-wbs-to-s3.js",
    "upload:itsm": "node scripts/upload-wbs-to-itsm.js",
    "verify:itsm": "node scripts/verify-wbs-itsm.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
